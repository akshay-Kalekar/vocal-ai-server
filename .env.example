# Ollama/Local LLM Configuration
# URL of the Ollama server (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Model name to use (examples: llama2, mistral, neural-chat, openchat)
# List available models at: http://localhost:11434/api/tags
MODEL_NAME=mistral:7b-instruct-q4_K_M

# Session Management
# Timeout in seconds for inactive sessions before cleanup (default: 3600 = 1 hour)
SESSION_TIMEOUT=3600

# Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Qwen TTS Configuration
# Set true to stream welcome TTS audio on WebSocket connect
TTS_ENABLED=false
TTS_MODEL_NAME=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
TTS_SPEAKER=Ryan
TTS_LANGUAGE=English
TTS_INSTRUCT=
TTS_WELCOME_TEXT=Welcome. You are connected to the low cost voice agent.
TTS_DEVICE_MAP=auto
TTS_DTYPE=bfloat16
TTS_ATTN_IMPL=flash_attention_2
TTS_CHUNK_SIZE=8192
# Seconds to wait for welcome synthesis (then audio_error + chat continues)
TTS_WELCOME_TIMEOUT=600
# Optional: cap generation length (smaller = faster welcome audio)
TTS_GEN_MAX_NEW_TOKENS=768
# Assistant reply TTS (after each LLM answer)
TTS_REPLY_TIMEOUT=600
# Max characters of assistant text sent to TTS (truncate long answers)
TTS_REPLY_MAX_CHARS=2000
# WebSocket audio: opus (default, needs libopus + opuslib-next) or wav
TTS_AUDIO_CODEC=opus
