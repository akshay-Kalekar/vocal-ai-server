# Ollama/Local LLM Configuration
# URL of the Ollama server (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Model name to use (examples: llama2, mistral, neural-chat, openchat)
# List available models at: http://localhost:11434/api/tags
MODEL_NAME=mistral:7b-instruct-q4_K_M

# Session Management
# Timeout in seconds for inactive sessions before cleanup (default: 3600 = 1 hour)
SESSION_TIMEOUT=3600

# Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Piper TTS (CPU-friendly). Install binary from https://github.com/rhasspy/piper/releases
# Download a voice .onnx + matching .onnx.json from Piper voices release assets.
TTS_ENABLED=false
PIPER_EXECUTABLE=piper
# Absolute or relative path to the voice model file, e.g. /path/to/en_US-lessac-medium.onnx
PIPER_MODEL_PATH=
# Optional: override JSON path (default is {PIPER_MODEL_PATH}.json)
# PIPER_VOICE_JSON=
# Optional extra args (see `piper --help`): PIPER_EXTRA_ARGS=--noise_scale 0.667
TTS_WELCOME_TEXT=Welcome. You are connected to the low cost voice agent.
TTS_CHUNK_SIZE=8192
TTS_WELCOME_TIMEOUT=600
TTS_REPLY_TIMEOUT=600
TTS_REPLY_MAX_CHARS=2000
# WebSocket audio: opus (needs libopus + opuslib-next) or wav
TTS_AUDIO_CODEC=opus
